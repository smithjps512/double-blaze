# Double Blaze platform environment variables.
# Copy to .env.local and fill in. The public marketing storefront builds and
# runs without any of these set; they enable auth, data, and email features.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Clerk (auth, roles: client / project_lead / admin) ---
# When unset, the app runs in public-only mode (no auth, marketing storefront only).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase (Postgres + RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email; powers the start-a-project form) ---
RESEND_API_KEY=
# Verified sender + the inbox that receives start-a-project submissions.
LEADS_FROM_EMAIL=hello@doubleblaze.solutions
LEADS_TO_EMAIL=hello@doubleblaze.solutions

# --- Stripe (Sprint 2 commerce). Use TEST keys (sk_test_/pk_test_) in dev. ---
# STRIPE_SECRET_KEY powers checkout, the webhook, and the stripe:seed script.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret from the Stripe webhook endpoint -> /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=

# --- Spark intake agent (Sprint 3). Anthropic Messages API, SERVER ONLY. ---
# ANTHROPIC_API_KEY is server-only. NEVER prefix it NEXT_PUBLIC_ and never
# expose it to the browser. When unset, Spark returns a graceful disabled state
# and the public storefront still builds and renders.
ANTHROPIC_API_KEY=
# Model Spark uses. Defaults to claude-sonnet-4-6 when unset.
SPARK_MODEL=claude-sonnet-4-6
# Optional: email of the staff user to assign as default project lead on brief
# acceptance. Falls back to the first project_lead/admin user when unset.
DEFAULT_PROJECT_LEAD_EMAIL=
